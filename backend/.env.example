# AI Provider: "ollama" (local) or "claude" (Anthropic API — recommended for production)
AI_PROVIDER=claude

# Required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Set to your Vercel frontend URL (comma-separated if multiple)
CORS_ORIGIN=https://deals-app.vercel.app

# Railway sets PORT automatically — do not change
PORT=3001

NODE_ENV=production
